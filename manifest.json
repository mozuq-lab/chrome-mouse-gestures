{
  "manifest_version": 3,
  "name": "Mouse Gestures",
  "version": "1.0.0",
  "description": "右ボタンドラッグでページ操作を行う個人用マウスジェスチャ拡張機能",
  "permissions": ["tabs", "sessions"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
